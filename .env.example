# OpenLPP - variables d'environnement (exemple)
# Copier ce fichier en .env et adapter les valeurs selon ton contexte.

# Chemin vers la base DuckDB utilisee par le backend FastAPI.
# Windows (dev local) :
# OPENLPP_DB=C:\DEV\07_PROJETS\OpenLPP\OpenLppV2\data\opendata_LPP.db
# Linux (serveur) :
OPENLPP_DB=/opt/openlpp/data/opendata_LPP.db
